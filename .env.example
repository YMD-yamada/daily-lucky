PORT=3000
# 0=Sunday ... 6=Saturday
NOTIFY_CRON=0 7 * * *
NOTIFY_TIMEZONE=Asia/Tokyo
# ntfy topic (e.g. yourname-lucky)
NTFY_TOPIC=
# ntfy server url
NTFY_BASE_URL=https://ntfy.sh
ENABLE_PUBLIC_TUNNEL=false
PUBLIC_TUNNEL_PROVIDER=cloudflared
# Optional for stable-ish URL, must be unique globally.
PUBLIC_SUBDOMAIN=
PUBLIC_TUNNEL_PORT=3000
CLOUDFLARED_PATH=C:\Users\cz7\AppData\Local\Microsoft\WinGet\Packages\Cloudflare.cloudflared_Microsoft.Winget.Source_8wekyb3d8bbwe\cloudflared.exe
# Optional: narrow to one sign in auto notification.
# If empty, all 12 signs are included.
DEFAULT_SIGN=
# ---- 収益化（任意・審査取得後）----
# 未設定のまま = 通常の商品直リンク（手数料なし）
# 楽天: 審査後に支給される「URL末尾のパラメータ」等を .env に記載
# 例: RAKUTEN_AFF_QUERY=scid=af_xxx_xxx_xxx_xxx
# RAKUTEN_AFF_QUERY=
# 中継型（先に元URLをエンコードして付与する形式のベースURL）
# RAKUTEN_AFF_WRAPPER_BASE=
# Amazon 国別アソシエイト: 将来 Amazon リンクに使う場合
# AMAZON_ASSOCIATE_TAG=
